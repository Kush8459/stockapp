# Copy this file to .env and adjust as needed.
# The Go backend reads these via Viper; `make dev-up` loads them into Docker Compose.

# --- HTTP server ---
APP_ENV=development
APP_HTTP_ADDR=:8080
# Comma-separated list of exact frontend origins (protocol + host + port).
# In production set to your real frontend URL, e.g.
#   APP_CORS_ORIGINS=https://your-domain.example
APP_CORS_ORIGINS=http://localhost:5173

# --- Postgres ---
POSTGRES_USER=stockapp
POSTGRES_PASSWORD=stockapp
POSTGRES_DB=stockapp
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# --- Price feed ---
# Which price source the worker uses:
#   mock    — in-process simulator, no network; ideal for demos/tests
#   real    — Yahoo Finance (NSE stocks) + mfapi.in (mutual funds), no keys
#   upstox  — official Upstox v3 WebSocket live ticks (needs UPSTOX_ACCESS_TOKEN)
#   polygon — (not implemented yet) will need POLYGON_API_KEY
PRICE_SOURCE=mock
POLYGON_API_KEY=

# --- Optional: Upstox live market data ---
# Get an API key at https://account.upstox.com/developer/apps
# Then run `cd backend && go run ./cmd/upstox-login` once a day to refresh
# the access token (expires ~3:30 AM IST).
# UPSTOX_API_KEY=
# UPSTOX_API_SECRET=
# UPSTOX_REDIRECT_URL=http://localhost:8080/api/v1/integrations/upstox/callback
# UPSTOX_ACCESS_TOKEN=

# --- Optional: news feed (for a future /news endpoint) ---
# Get a free key at https://newsapi.org/
# NEWSAPI_KEY=

# --- Frontend (used only by Vite) ---
# In production, point at your API's HTTPS URL — and use wss:// for the WS,
# since browsers block ws:// from HTTPS pages. Example:
#   VITE_API_URL=https://api.your-domain.example
#   VITE_WS_URL=wss://api.your-domain.example
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
